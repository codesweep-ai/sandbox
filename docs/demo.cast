{"version": 2, "width": 78, "height": 20, "timestamp": 1750000000, "env": {"TERM": "xterm-256color", "SHELL": "/bin/bash"}, "title": "cs-sandbox \u2014 create \u2192 work \u2192 fetch \u2192 destroy"}
[0.0, "o", "\u001b[38;5;77m$ \u001b[0m"]
[1.344, "o", "\u001b[38;5;245m# one sandbox, two repos checked in side by side\u001b[0m\r\n"]
[1.344, "o", "\u001b[38;5;77m$ \u001b[0m"]
[3.332, "o", "\u001b[97m./cs-sandbox create feature --repo ~/projects/api --repo ~/projects/web\u001b[0m\r\n"]
[3.332, "o", "\u001b[38;5;252mcreated feature \u001b[38;5;240m(microVM: ssh port 2300, 10.89.0.200, 4vcpu/4096MiB)\u001b[0m\r\n"]
[3.552, "o", "\u001b[38;5;252m  ~/api  \u001b[38;5;179m\u2192 branch cs-sandbox/feature\u001b[0m\r\n"]
[3.772, "o", "\u001b[38;5;252m  ~/web  \u001b[38;5;179m\u2192 branch cs-sandbox/feature\u001b[0m\r\n"]
[4.492, "o", "\u001b[38;5;77m$ \u001b[0m"]
[5.5, "o", "\u001b[97mssh feature\u001b[38;5;245m            # in, by name\u001b[0m\r\n"]
[5.8, "o", "\u001b[38;5;44m[feature]$ \u001b[0m"]
[6.388, "o", "\u001b[97mcd ~/api && cs-claude\u001b[0m\r\n"]
[6.388, "o", "\u001b[38;5;179m  Claude Code \u001b[38;5;240m(signed in, inherits your host login)\u001b[0m\r\n"]
[6.608, "o", "\u001b[38;5;252m  \u203a add a /version endpoint and commit when done\u001b[0m\r\n"]
[6.958, "o", "\r  \u001b[38;5;215m\u2736 Cogitating\u2026\u001b[0m \u001b[38;5;245m(1s \u00b7 \u2191 0.2k tokens \u00b7 esc to interrupt)\u001b[0m\u001b[K"]
[7.658, "o", "\r  \u001b[38;5;215m* Cogitating\u2026\u001b[0m \u001b[38;5;245m(1s \u00b7 \u2191 0.5k tokens \u00b7 esc to interrupt)\u001b[0m\u001b[K"]
[8.358, "o", "\r  \u001b[38;5;215m\u2736 Dillydallying\u2026\u001b[0m \u001b[38;5;245m(2s \u00b7 \u2191 0.8k tokens \u00b7 esc to interrupt)\u001b[0m\u001b[K"]
[9.058, "o", "\r  \u001b[38;5;215m\u2055 Synthesizing\u2026\u001b[0m \u001b[38;5;245m(3s \u00b7 \u2191 1.1k tokens \u00b7 esc to interrupt)\u001b[0m\u001b[K"]
[9.758, "o", "\r  \u001b[38;5;215m\u2736 Noodling\u2026\u001b[0m \u001b[38;5;245m(4s \u00b7 \u2191 1.4k tokens \u00b7 esc to interrupt)\u001b[0m\u001b[K"]
[10.458, "o", "\r  \u001b[38;5;215m* Finagling\u2026\u001b[0m \u001b[38;5;245m(5s \u00b7 \u2191 1.6k tokens \u00b7 esc to interrupt)\u001b[0m\u001b[K"]
[11.658, "o", "\r\u001b[2K\u001b[38;5;240m  edited server.js  \u2022  GET /version \u2192 {\"version\":\"1.4.0\"}\u001b[0m\r\n"]
[11.878, "o", "\u001b[38;5;77m  \u2713 committed \u001b[38;5;252m\"add /version endpoint\"  on cs-sandbox/feature\u001b[0m\r\n"]
[12.498, "o", "\u001b[38;5;44m[feature]$ \u001b[0m"]
[12.61, "o", "\u001b[97mexit\u001b[0m\r\n"]
[12.91, "o", "\u001b[38;5;77m$ \u001b[0m"]
[14.114, "o", "\u001b[38;5;245m# pull the agent's commits back to the host\u001b[0m\r\n"]
[14.114, "o", "\u001b[38;5;77m$ \u001b[0m"]
[14.842, "o", "\u001b[97m./cs-sandbox fetch feature\u001b[0m\r\n"]
[14.842, "o", "\u001b[38;5;252mfetched cs-sandbox/feature \u001b[38;5;179m\u2192 ~/projects/api (1 commit)\u001b[0m\r\n"]
[15.562, "o", "\u001b[38;5;77m$ \u001b[0m"]
[16.57, "o", "\u001b[38;5;245m# done? throw the whole sandbox away\u001b[0m\r\n"]
[16.57, "o", "\u001b[38;5;77m$ \u001b[0m"]
[17.354, "o", "\u001b[97m./cs-sandbox destroy feature\u001b[0m\r\n"]
[17.354, "o", "\u001b[38;5;252mdestroyed feature\u001b[0m\r\n"]
