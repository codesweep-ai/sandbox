#!/usr/bin/env python3
# vsock-connect <firecracker-vsock-uds> [guest-port]
# SSH ProxyCommand: connect to a Firecracker vsock unix socket, perform the host->guest
# CONNECT handshake, then relay stdin/stdout to the guest's vsock port (default 22).
import socket, sys, os, threading

uds = sys.argv[1]
port = sys.argv[2] if len(sys.argv) > 2 else "22"
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
try:
    s.connect(uds)
except OSError as e:
    sys.exit("cs-sandbox-vsock-connect: cannot connect %s: %s" % (uds, e))
s.sendall(b"CONNECT " + port.encode() + b"\n")
# Firecracker replies "OK <host_port>\n" on success, or closes on failure.
line = b""
while not line.endswith(b"\n"):
    c = s.recv(1)
    if not c:
        sys.exit("cs-sandbox-vsock-connect: CONNECT failed (guest port %s not listening?)" % port)
    line += c
if not line.startswith(b"OK"):
    sys.exit("cs-sandbox-vsock-connect: CONNECT rejected: " + line.decode(errors="replace").strip())

def stdin_to_sock():
    while True:
        d = os.read(0, 65536)
        if not d:
            try: s.shutdown(socket.SHUT_WR)
            except OSError: pass
            return
        s.sendall(d)

t = threading.Thread(target=stdin_to_sock, daemon=True)
t.start()
while True:
    d = s.recv(65536)
    if not d:
        break
    os.write(1, d)
